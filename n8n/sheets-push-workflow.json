      "parameters": {
        "jsCode": "// Split { rows: [...] } into individual items for the Google Sheets node\n// n8n webhook (typeVersion 2) nests the POST body under .body\nconst raw = $input.first().json;\nconst payload = raw.body ?? raw;\nconst rows = Array.isArray(payload.rows) ? payload.rows : [];\nif (rows.length === 0) return [{ json: { _empty: true } }];\nreturn rows.map(row => ({ json: row }));\n"
      },
